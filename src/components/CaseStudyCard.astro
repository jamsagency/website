---
interface Props {
  title: string;
  slug: string;
  tags: string[];
  oneliner: string;
  image?: string;
  imageAlt?: string;
}

const { title, slug, tags, oneliner, image, imageAlt } = Astro.props;
---

<a href={`/work/${slug}`} class="card group flex flex-col no-underline">
  <!-- Image area -->
  <div class="aspect-[4/3] bg-neutral-100 overflow-hidden">
    {image ? (
      <img
        src={image}
        alt={imageAlt ?? title}
        width="600"
        height="450"
        class="w-full h-full object-cover transition-transform duration-[400ms] ease-out-custom group-hover:scale-[1.02]"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-full bg-neutral-100 flex items-center justify-center">
        <img src="/jams-logo-iso-black.svg" alt="" width="40" height="40" class="opacity-20" />
      </div>
    )}
  </div>

  <!-- Content -->
  <div class="flex flex-col gap-3 p-6">
    <div class="flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="chip">{tag}</span>
      ))}
    </div>
    <h3 class="font-display text-h3 text-neutral-900 leading-snug">{title}</h3>
    <p class="font-sans text-p-s text-neutral-700">{oneliner}</p>
    <span class="font-sans text-p-s font-medium text-violet-600 mt-1 transition-colors duration-fast group-hover:text-violet-700">
      View project &rarr;
    </span>
  </div>
</a>
