---
import LandingPageLayout from '../layouts/LandingPageLayout.astro';
import CTASection from '../components/CTASection.astro';
---
<LandingPageLayout
  title="Custom Front-End for Checkfront | Jams"
  description="Custom Bubble front-ends for Checkfront operators — keep your back-end, replace the guest-facing booking experience."
  vertical="Custom Front-End for Checkfront"
>
  <!-- COPY NEEDED -->
  <section class="px-3 pt-4 pb-10 md:px-4 md:pb-12">
    <div class="rounded-[24px] pt-[120px] pb-[64px]" style="background: var(--neutral-100);">
      <div class="container">
        <div class="max-w-2xl flex flex-col gap-4">
          <span class="eyebrow">Checkfront</span>
          <h1 class="font-display text-h1 text-neutral-900">Custom front-end for Checkfront</h1>
          <p class="font-sans text-p-l text-neutral-500 mt-2">Copy coming soon.</p>
        </div>
      </div>
    </div>
  </section>
  <CTASection />
</LandingPageLayout>
