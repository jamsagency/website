---
import LandingPageLayout from '../layouts/LandingPageLayout.astro';
import CTASection from '../components/CTASection.astro';
---
<LandingPageLayout
  title="Cloudflare + Bubble Hybrid Architecture | Jams"
  description="The Jams hybrid architecture — Bubble for the product layer, Cloudflare Workers for performance-critical operations and AI edge functions."
  vertical="Cloudflare Hybrid Architecture"
>
  <!-- COPY NEEDED -->
  <section class="px-3 pt-4 pb-10 md:px-4 md:pb-12">
    <div class="rounded-[24px] pt-[120px] pb-[64px]" style="background: var(--neutral-100);">
      <div class="container">
        <div class="max-w-2xl flex flex-col gap-4">
          <span class="eyebrow">Cloudflare</span>
          <h1 class="font-display text-h1 text-neutral-900">Cloudflare + Bubble hybrid architecture</h1>
          <p class="font-sans text-p-l text-neutral-500 mt-2">Copy coming soon.</p>
        </div>
      </div>
    </div>
  </section>
  <CTASection />
</LandingPageLayout>
