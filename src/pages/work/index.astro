---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CaseStudyCard from '../../components/CaseStudyCard.astro';
import CTASection from '../../components/CTASection.astro';

const projects = [
  { title: 'The Fold',                slug: 'the-fold',                tags: ['Mobile app', 'AI agent', 'Community platform'],        oneliner: 'WhatsApp deal flow, replaced by Alfred — an AI concierge for private equity.',                                        image: '/thefold-cover.png',  imageAlt: 'The Fold app interface' },
  { title: 'DropCar',                 slug: 'dropcar',                 tags: ['Web app', 'Booking flow'],   oneliner: 'A two-sided logistics business, unified into one digital story.',                                                      image: '/dropcar-cover.png',  imageAlt: 'DropCar web app' },
  { title: 'The Arena',               slug: 'the-arena',               tags: ['Web app', 'AI automation', 'EdTech', 'Gamification'],  oneliner: 'Manual Notion pages and one-by-one ChatGPT reports, replaced by an automated student platform.',                       image: '/thearena-cover.png', imageAlt: 'The Arena student platform' },
  { title: 'Red Horse Mountain Ranch',slug: 'red-horse-mountain-ranch',tags: ['Web app', 'Booking platform', 'Hospitality'],          oneliner: 'A luxury dude ranch with no direct bookings, replaced by a branded booking flow with Stripe deposits.',                 image: '/redhorse-cover.png', imageAlt: 'Red Horse Mountain Ranch booking platform' },
  { title: 'Qmius',                   slug: 'qmius',                   tags: ['Web app', 'B2B marketplace'],                          oneliner: '', image: '/qmius-cover.png',       imageAlt: 'Qmius marketplace',           comingSoon: true },
  { title: 'The 93% Club',            slug: '93-percent-club',         tags: ['Web app', 'Community platform'],                       oneliner: '', image: '/93percent-cover.png',   imageAlt: 'The 93% Club platform',       comingSoon: true },
  { title: 'Fletech',                 slug: 'fletech',                 tags: ['Web app'],                                             oneliner: '', image: '/fletech-cover.png',     imageAlt: 'Fletech web app',             comingSoon: true },
  { title: 'Buyer Match',             slug: 'buyer-match',             tags: ['Web app', 'AI agent'],                                 oneliner: '', image: '/buyermatch-cover.png',  imageAlt: 'Buyer Match app',             comingSoon: true },
];
---

<BaseLayout
  title="Client Work — Custom Software and AI Products | Jams"
  description="Case studies across hospitality, B2B SaaS, community platforms, marketplaces, and AI agents."
>
  <!-- Internal hero -->
  <section class="px-3 pt-4 pb-10 md:px-4 md:pb-12">
    <div class="rounded-[24px] pt-[120px] pb-[64px]" style="background: var(--neutral-100);">
      <div class="container">
        <div class="flex flex-col gap-4">
          <span class="eyebrow">Work</span>
          <h1 class="font-display text-h1 text-neutral-900">The work</h1>
        </div>
      </div>
    </div>
  </section>

  <!-- Project grid -->
  <section class="section hairline">
    <div class="container">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        {projects.map((p) => <CaseStudyCard {...p} />)}
      </div>
    </div>
  </section>
  <CTASection />
</BaseLayout>
