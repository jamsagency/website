---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CaseStudyCard from '../../components/CaseStudyCard.astro';
import CTASection from '../../components/CTASection.astro';

const projects = [
  { title: 'The Fold',                slug: 'the-fold',                tags: ['Mobile app', 'AI agent', 'Community platform'],        oneliner: 'WhatsApp deal flow, replaced by Alfred — an AI concierge for private equity.' },
  { title: 'DropCar',                 slug: 'dropcar',                 tags: ['Web app', 'Brand and design', 'High-converting UX'],    oneliner: 'A two-sided logistics business, unified into one digital story.' },
  { title: 'Emendu',                  slug: 'emendu',                  tags: ['Web app', 'B2B SaaS', 'AI agent'],                      oneliner: 'Thousands of devices managed in spreadsheets, replaced by a full SaaS platform with an AI agent.' },
  { title: 'The Arena',               slug: 'the-arena',               tags: ['Web app', 'AI automation', 'EdTech', 'Gamification'],   oneliner: 'Manual Notion pages and one-by-one ChatGPT reports, replaced by an automated student platform.' },
  { title: 'Red Horse Mountain Ranch',slug: 'red-horse-mountain-ranch',tags: ['Web app', 'Booking platform', 'Hospitality'],           oneliner: 'A luxury dude ranch with no direct bookings, replaced by a branded booking flow with Stripe deposits.' },
  { title: 'Qmius',                   slug: 'qmius',                   tags: ['Web app', 'B2B marketplace'],                           oneliner: 'Coming soon.' },
  { title: 'The 93% Club',            slug: '93-percent-club',         tags: ['Web app', 'Community platform'],                        oneliner: 'Coming soon.' },
  { title: 'Fletech',                 slug: 'fletech',                 tags: ['Web app'],                                              oneliner: 'Coming soon.' },
];
---

<BaseLayout
  title="Client Work — Custom Software and AI Products | Jams"
  description="Case studies across hospitality, B2B SaaS, community platforms, marketplaces, and AI agents."
>
  <!-- Internal hero -->
  <section class="px-3 pt-4 pb-10 md:px-4 md:pb-12">
    <div class="rounded-[24px] pt-[120px] pb-[64px]" style="background: var(--neutral-100);">
      <div class="container">
        <div class="flex flex-col gap-4">
          <span class="eyebrow">Work</span>
          <h1 class="font-display text-h1 text-neutral-900">The work</h1>
        </div>
      </div>
    </div>
  </section>

  <!-- Project grid -->
  <section class="section hairline">
    <div class="container">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {projects.map((p) => <CaseStudyCard {...p} />)}
      </div>
    </div>
  </section>
  <CTASection />
</BaseLayout>
