---
import BaseLayout from '../layouts/BaseLayout.astro';

const processSteps = [
  {
    n: '1',
    title: 'Apply',
    body: 'Fill out the form below. It takes about 5 minutes. Tell us about the problem, the business, and where you are right now.',
  },
  {
    n: '2',
    title: 'Free shaping workshop',
    body: 'We review your submission and reach out to schedule a free 60-minute session. We map your business problem together and figure out what to build and why. No pitch, no deck — just honest strategy. You leave with clarity whether or not we move forward.',
  },
  {
    n: '3',
    title: 'The Blueprint',
    body: 'If we move forward, every engagement starts with a Blueprint: a two-week paid discovery process where we define exactly what to build, in what order, and why. That is where the real work begins.',
  },
];

const faqs = [
  {
    q: 'What exactly do you build?',
    a: 'Custom web and mobile applications. Not websites, not templates, not off-the-shelf SaaS tools with your logo on them. We build products from scratch: booking platforms, marketplaces, community platforms, internal ops tools, AI-powered apps. If your business has a specific workflow and no existing software handles it the way you need, that is what we build.',
  },
  {
    q: 'Do you work with no-code? What does that mean for us?',
    a: 'Yes. Our primary build tool is Bubble, the most powerful no-code platform available. In practice, it means we build faster and at a lower cost than traditional development, without compromising the end result. Bubble handles payments, AI integrations, real-time data, complex logic, and multi-role platforms. For performance-critical or backend-heavy work, we use a hybrid architecture with Cloudflare and Convex on top of Bubble.',
  },
  {
    q: 'How do you scope a project and how is it priced?',
    a: 'Every engagement starts with a Blueprint: a paid, two-week discovery process where we define exactly what gets built, in what order, and why. The Blueprint starts at $3,500. After the Blueprint, development runs as a monthly engagement: $8,000 per month for a full dedicated team, or $5,000 per month for a sprint-based model. ',
  },
  {
    q: 'What happens if the scope changes?',
    a: 'It gets acknowledged in writing and discussed before anything changes. We use a formal scope change process: if a feature grows or a new requirement surfaces mid-build, we stop and have a conversation. We decide together whether it fits the current budget and timeline, whether to defer it, or whether to price it separately.',
  },
  {
    q: 'How long does a typical project take?',
    a: 'The Blueprint takes two weeks. After that, most first-version products ship in 8 to 12 weeks depending on complexity. Booking flows and internal tools tend toward the shorter end. Marketplaces, community platforms, and AI-integrated products tend toward the longer end.',
  },
  {
    q: 'Who owns the code and design at the end?',
    a: 'You do. The Figma files, the Bubble application, all design assets, all documentation transfer to you at the end of the engagement. If you want to work with a different team after us, you can.',
  },
  {
    q: 'What do we need to provide to get started?',
    a: 'For the Blueprint: access to any existing systems or tools (if applicable), time from one or two decision-makers (two 90-minute sessions over two weeks), and a clear description of the problem you are trying to solve. You do not need a spec, a wireframe, or a technical brief.',
  },
  {
    q: 'How involved do we need to be during the project?',
    a: 'More than most clients expect, less than they fear. In the Blueprint, you are in two facilitated sessions. During the build, you review working product every Friday and give feedback within 48 hours.',
  },
  {
    q: 'What happens after launch?',
    a: 'Before you launch, we agree on what comes next. Three options: an ongoing retainer ($5,000 to $8,000 per month), a support agreement, or a clean handover. We do not disappear after delivery.',
  },
  {
    q: 'Can we see something you have built that is similar to what we need?',
    a: 'Probably yes. The portfolio is at jams.agency/work. If you want to see something specific to your use case before booking a call, email j@jams.agency with a one-line description of what you are building.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: { '@type': 'Answer', text: a },
  })),
};
---

<BaseLayout
  title="Book Your Free Shaping Workshop | Jams"
  description="A free 60-minute session to map your business problem and figure out exactly what to build. No pitch, no jargon."
  noindex={true}
  schema={faqSchema}
>

  <!-- Hero -->
  <section class="px-3 pt-4 pb-10 md:px-4 md:pb-12">
    <div class="rounded-[24px] pt-[160px] pb-[80px]" style="background: var(--neutral-100);">
      <div class="container">
        <div class="max-w-2xl mx-auto flex flex-col items-center text-center gap-6">
          <span class="eyebrow">Apply</span>
          <h1 class="font-display text-h1 text-neutral-900">
            Thinking about AI in your business, or have a specific workflow that software should be handling? Tell us what you are working with.
          </h1>
          <p class="font-sans text-p-l text-neutral-700">
            We build custom web and mobile applications for businesses that have outgrown what off-the-shelf tools can do. Not a dev team that executes tickets — a team that figures out what to build, designs it, builds it, and stays involved after launch. If you are not sure exactly what to build yet, that is fine. Figuring that out is part of what we do.
          </p>
          <p class="font-sans text-p text-neutral-700">
            Fill out the form below. We review every submission and get back to you within 24 hours.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="section hairline" aria-labelledby="next-steps-heading">
    <div class="container flex flex-col gap-12">
      <h2 id="next-steps-heading" class="eyebrow">What happens next</h2>
      <ol class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {processSteps.map(({ n, title, body }) => (
          <li class="flex flex-col gap-4">
            <span class="font-display text-h3 text-violet-500">{n}</span>
            <h3 class="font-display text-h4 text-neutral-900">{title}</h3>
            <p class="font-sans text-p text-neutral-700">{body}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Multi-step form -->
  <section class="section hairline" aria-labelledby="form-heading">
    <div class="container">
      <div class="max-w-2xl mx-auto flex flex-col gap-8">

        <div class="flex flex-col gap-2">
          <h2 id="form-heading" class="font-display text-h2 text-neutral-900">Apply to work with Jams</h2>
          <p class="font-sans text-p-s text-neutral-500">No commitment on either side until after the discovery call. This takes about 5 minutes.</p>
        </div>

        <!-- Form card -->
        <div id="form-card" class="rounded-2xl overflow-hidden" style="border: 1px solid #E5E5E5; background: #fff; box-shadow: 0 2px 10px 0 rgba(0,0,0,0.06), inset 0 2px 2px 0 #FEFEFE;">

          <!-- Progress -->
          <div class="px-8 md:px-10 pt-8 pb-0 flex flex-col gap-3">
            <span id="step-label" class="font-sans uppercase tracking-widest" style="font-size: 11px; color: #A3A3A3;">Step 1 of 4</span>
            <div class="h-px w-full rounded-full" style="background: #F3F3F5;">
              <div id="progress-fill" style="height: 1px; width: 25%; border-radius: 999px; background: #7C3AED; transition: width 300ms ease;"></div>
            </div>
          </div>

          <!-- Form -->
          <form id="apply-form" novalidate>

            <!-- ── Step 1: Who you are + the problem ── -->
            <div class="apply-step" data-step="1">
              <div class="p-8 md:p-10 flex flex-col gap-7">

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div class="flex flex-col gap-2">
                    <label class="field-label" for="f-name">Your name</label>
                    <input id="f-name" name="name" type="text" required class="form-input" placeholder="Juan Germano" autocomplete="name" />
                  </div>
                  <div class="flex flex-col gap-2">
                    <label class="field-label" for="f-email">Email address</label>
                    <input id="f-email" name="email" type="email" required class="form-input" placeholder="you@company.com" autocomplete="email" />
                  </div>
                </div>

                <div class="flex flex-col gap-2">
                  <label class="field-label" for="f-problem">What problem are you trying to solve?</label>
                  <p class="field-hint">Tell us what is broken, missing, or taking too long. Not the solution you have in mind — the problem itself.</p>
                  <textarea id="f-problem" name="problem" required rows="5" class="form-textarea" placeholder="Describe the problem in plain terms..."></textarea>
                </div>

              </div>
            </div>

            <!-- ── Step 2: Users + existing work + success ── -->
            <div class="apply-step" data-step="2" style="display:none;">
              <div class="p-8 md:p-10 flex flex-col gap-7">

                <div class="flex flex-col gap-2">
                  <label class="field-label" for="f-users">Who uses this product?</label>
                  <p class="field-hint">Describe the main person this is built for. Customer, employee, member — and if there are multiple user types, list them all.</p>
                  <textarea id="f-users" name="users" required rows="4" class="form-textarea" placeholder="e.g. Ranch guests booking stays, and an admin managing reservations..."></textarea>
                </div>

                <div class="flex flex-col gap-3">
                  <span class="field-label">Have you built anything for this yet?</span>
                  <div class="flex flex-col gap-2">
                    <label class="radio-card"><input type="radio" name="existing" value="no" /><span>No, starting from scratch</span></label>
                    <label class="radio-card"><input type="radio" name="existing" value="yes-app" /><span>Yes, we have an existing app or tool</span></label>
                    <label class="radio-card"><input type="radio" name="existing" value="yes-mockups" /><span>Yes, we have mockups or a spec</span></label>
                  </div>
                </div>

                <div id="existing-detail" class="flex flex-col gap-2" style="display:none;">
                  <label class="field-hint block" for="f-existing-detail">Describe what exists and what is working or broken about it.</label>
                  <textarea id="f-existing-detail" name="existing_detail" rows="3" class="form-textarea" placeholder="What exists, and what is working or broken..."></textarea>
                </div>

                <div class="flex flex-col gap-2">
                  <label class="field-label" for="f-success">What does success look like in 6 months?</label>
                  <p class="field-hint">Be specific. A number, a behavior, an outcome. Not "a great product."</p>
                  <textarea id="f-success" name="success" required rows="3" class="form-textarea" placeholder="In 6 months we will have..."></textarea>
                </div>

              </div>
            </div>

            <!-- ── Step 3: Timeline + revenue + team ── -->
            <div class="apply-step" data-step="3" style="display:none;">
              <div class="p-8 md:p-10 flex flex-col gap-7">

                <div class="flex flex-col gap-3">
                  <span class="field-label">What is your timeline?</span>
                  <div class="flex flex-col gap-2">
                    <label class="radio-card"><input type="radio" name="timeline" value="asap" /><span>As soon as possible</span></label>
                    <label class="radio-card"><input type="radio" name="timeline" value="3months" /><span>Within 3 months</span></label>
                    <label class="radio-card"><input type="radio" name="timeline" value="6months" /><span>Within 6 months</span></label>
                    <label class="radio-card"><input type="radio" name="timeline" value="no-deadline" /><span>No hard deadline yet</span></label>
                  </div>
                </div>

                <div id="deadline-detail" class="flex flex-col gap-2" style="display:none;">
                  <label class="field-hint block" for="f-deadline">Is there a fixed event, launch date, or deadline driving this?</label>
                  <input id="f-deadline" name="deadline" type="text" class="form-input" placeholder="e.g. Product launch on June 1st" />
                </div>

                <div class="flex flex-col gap-3">
                  <span class="field-label">What is your company's annual revenue?</span>
                  <p class="field-hint">This helps us understand scale and scope early.</p>
                  <div class="grid grid-cols-2 gap-2">
                    <label class="radio-card"><input type="radio" name="revenue" value="pre-revenue" /><span>Pre-revenue</span></label>
                    <label class="radio-card"><input type="radio" name="revenue" value="under-500k" /><span>Under $500k</span></label>
                    <label class="radio-card"><input type="radio" name="revenue" value="500k-2m" /><span>$500k – $2M</span></label>
                    <label class="radio-card"><input type="radio" name="revenue" value="2m-10m" /><span>$2M – $10M</span></label>
                    <label class="radio-card"><input type="radio" name="revenue" value="over-10m" /><span>Over $10M</span></label>
                    <label class="radio-card"><input type="radio" name="revenue" value="prefer-not" /><span>Prefer not to say</span></label>
                  </div>
                </div>

                <div class="flex flex-col gap-3">
                  <span class="field-label">How many people are on your team?</span>
                  <div class="grid grid-cols-2 gap-2">
                    <label class="radio-card"><input type="radio" name="team" value="solo" /><span>Just me</span></label>
                    <label class="radio-card"><input type="radio" name="team" value="2-5" /><span>2 to 5</span></label>
                    <label class="radio-card"><input type="radio" name="team" value="6-20" /><span>6 to 20</span></label>
                    <label class="radio-card"><input type="radio" name="team" value="21-100" /><span>21 to 100</span></label>
                    <label class="radio-card col-span-2"><input type="radio" name="team" value="over-100" /><span>Over 100</span></label>
                  </div>
                </div>

              </div>
            </div>

            <!-- ── Step 4: Budget + source ── -->
            <div class="apply-step" data-step="4" style="display:none;">
              <div class="p-8 md:p-10 flex flex-col gap-7">

                <div class="flex flex-col gap-3">
                  <span class="field-label">What is your budget for the build?</span>
                  <p class="field-hint">The Blueprint starts at $3,500. Development starts at $5,000 per month. Where do you see yourself?</p>
                  <div class="flex flex-col gap-2">
                    <label class="radio-card"><input type="radio" name="budget" value="under-10k" /><span>Under $10k</span></label>
                    <label class="radio-card"><input type="radio" name="budget" value="10k-20k" /><span>$10k to $20k</span></label>
                    <label class="radio-card"><input type="radio" name="budget" value="20k-50k" /><span>$20k to $50k</span></label>
                    <label class="radio-card"><input type="radio" name="budget" value="over-50k" /><span>Over $50k</span></label>
                    <label class="radio-card"><input type="radio" name="budget" value="not-sure" /><span>Not sure yet</span></label>
                  </div>
                </div>

                <div class="flex flex-col gap-3">
                  <span class="field-label">How did you find us?</span>
                  <div class="grid grid-cols-2 gap-2">
                    <label class="radio-card"><input type="radio" name="source" value="referral" /><span>Referral</span></label>
                    <label class="radio-card"><input type="radio" name="source" value="linkedin" /><span>LinkedIn</span></label>
                    <label class="radio-card"><input type="radio" name="source" value="search" /><span>Search</span></label>
                    <label class="radio-card"><input type="radio" name="source" value="content" /><span>Content</span></label>
                    <label class="radio-card col-span-2"><input type="radio" name="source" value="other" /><span>Other</span></label>
                  </div>
                </div>

                <div id="referral-detail" class="flex flex-col gap-2" style="display:none;">
                  <label class="field-hint block" for="f-referral">Who referred you?</label>
                  <input id="f-referral" name="referral" type="text" class="form-input" placeholder="Name of the person who referred you" />
                </div>

              </div>
            </div>

            <!-- Navigation -->
            <div class="flex items-center px-8 md:px-10 py-6" style="border-top: 1px solid #F3F3F5;">
              <button type="button" id="back-btn" class="font-sans text-p-s text-neutral-400 hover:text-neutral-700 transition-colors duration-fast" style="display:none;">← Back</button>
              <div class="ml-auto">
                <button type="button" id="next-btn" class="btn-primary rounded-pill py-3 px-6 font-sans text-p-s">Continue →</button>
                <button type="submit" id="submit-btn" class="btn-primary rounded-pill py-3 px-6 font-sans text-p-s" style="display:none;">Submit application</button>
              </div>
            </div>

          </form>
        </div>

        <!-- Success state -->
        <div id="success-card" class="rounded-2xl p-10 md:p-14 flex-col items-center gap-6 text-center" style="display:none; border: 1px solid #E5E5E5; background: #fff; box-shadow: 0 2px 10px 0 rgba(0,0,0,0.06);">
          <div class="w-14 h-14 rounded-full flex items-center justify-center shrink-0 mx-auto" style="background: rgba(124,58,237,0.07);">
            <i class="ph ph-check-circle" style="font-size: 28px; color: #7C3AED;"></i>
          </div>
          <div class="flex flex-col gap-3 max-w-sm mx-auto">
            <h3 class="font-display text-h2 text-neutral-900">We got it.</h3>
            <p class="font-sans text-p text-neutral-600">Someone from Jams will review your submission and reach out within 24 hours. If you want to get ahead of it, you can book a call directly.</p>
          </div>
          <a href="https://cal.com/jjams/discovery" class="btn-primary rounded-pill py-3 px-7 font-sans text-p-s inline-block mt-2">Book a call now</a>
        </div>

      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section hairline" aria-labelledby="faq-start-heading">
    <div class="container">
      <div class="max-w-2xl mx-auto flex flex-col gap-10">
        <h2 id="faq-start-heading" class="font-display text-h2 text-neutral-900">Common questions</h2>
        <dl class="flex flex-col divide-y divide-neutral-150">
          {faqs.map(({ q, a }) => (
            <details class="group py-6">
              <summary class="flex items-center justify-between gap-4 cursor-pointer list-none font-display text-h4 text-neutral-900">
                {q}
                <span class="shrink-0 text-violet-500 transition-transform duration-fast group-open:rotate-45" aria-hidden="true">+</span>
              </summary>
              <p class="font-sans text-p text-neutral-700 mt-4 leading-relaxed">{a}</p>
            </details>
          ))}
        </dl>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .field-label {
    font-family: inherit;
    font-size: 14px;
    font-weight: 500;
    color: #262626;
    line-height: 1.4;
  }
  .field-hint {
    font-family: inherit;
    font-size: 13px;
    color: #A3A3A3;
    line-height: 1.6;
    margin-top: -4px;
  }
  .form-input,
  .form-textarea {
    width: 100%;
    border: 1px solid #E5E5E5;
    border-radius: 12px;
    padding: 12px 16px;
    font-family: inherit;
    font-size: 15px;
    line-height: 1.6;
    color: #171717;
    background: #fff;
    outline: none;
    transition: border-color 150ms ease;
  }
  .form-input:focus,
  .form-textarea:focus {
    border-color: #A78BFA;
  }
  .form-input.error,
  .form-textarea.error {
    border-color: #F87171;
  }
  .form-textarea {
    resize: vertical;
    min-height: 100px;
  }
  .radio-card {
    display: flex;
    align-items: center;
    gap: 10px;
    border: 1px solid #E5E5E5;
    border-radius: 12px;
    padding: 12px 16px;
    cursor: pointer;
    font-family: inherit;
    font-size: 14px;
    color: #525252;
    line-height: 1.4;
    transition: border-color 120ms ease, background-color 120ms ease, color 120ms ease;
    user-select: none;
  }
  .radio-card input[type="radio"] {
    position: absolute;
    opacity: 0;
    pointer-events: none;
    width: 0;
    height: 0;
  }
  .radio-card:hover {
    border-color: #C4B5FD;
  }
  .radio-card:has(input:checked) {
    border-color: #7C3AED;
    background-color: rgba(124, 58, 237, 0.04);
    color: #171717;
    font-weight: 500;
  }
  .apply-step {
    animation: stepIn 200ms ease;
  }
  @keyframes stepIn {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  ::placeholder {
    color: #A3A3A3;
  }
</style>

<script>
  const TOTAL = 4;
  let current = 1;

  const formCard = document.getElementById('form-card');
  const successCard = document.getElementById('success-card');
  const stepLabel = document.getElementById('step-label');
  const progressFill = document.getElementById('progress-fill');
  const backBtn = document.getElementById('back-btn');
  const nextBtn = document.getElementById('next-btn');
  const submitBtn = document.getElementById('submit-btn');
  const form = document.getElementById('apply-form');

  function getStep(n) {
    return document.querySelector('.apply-step[data-step="' + n + '"]');
  }

  function goto(n) {
    document.querySelectorAll('.apply-step').forEach(el => el.style.display = 'none');
    const step = getStep(n);
    if (step) step.style.display = 'block';
    current = n;

    stepLabel.textContent = 'Step ' + n + ' of ' + TOTAL;
    progressFill.style.width = ((n / TOTAL) * 100) + '%';

    backBtn.style.display = n > 1 ? 'block' : 'none';
    nextBtn.style.display = n === TOTAL ? 'none' : 'block';
    submitBtn.style.display = n === TOTAL ? 'block' : 'none';

    const top = formCard.getBoundingClientRect().top + window.scrollY - 120;
    window.scrollTo({ top, behavior: 'smooth' });
  }

  function validate(n) {
    const step = getStep(n);
    if (!step) return true;
    let ok = true;
    step.querySelectorAll('[required]').forEach(el => {
      if (!el.value.trim()) {
        el.classList.add('error');
        ok = false;
      } else {
        el.classList.remove('error');
      }
    });
    return ok;
  }

  // Conditional fields
  document.addEventListener('change', e => {
    const t = e.target;
    if (t.type !== 'radio') return;
    if (t.name === 'existing') {
      document.getElementById('existing-detail').style.display = t.value !== 'no' ? 'flex' : 'none';
    }
    if (t.name === 'timeline') {
      document.getElementById('deadline-detail').style.display = t.value !== 'no-deadline' ? 'flex' : 'none';
    }
    if (t.name === 'source') {
      document.getElementById('referral-detail').style.display = t.value === 'referral' ? 'flex' : 'none';
    }
  });

  // Clear error on input
  document.addEventListener('input', e => e.target.classList.remove('error'));

  backBtn.addEventListener('click', () => goto(current - 1));
  nextBtn.addEventListener('click', () => { if (validate(current)) goto(current + 1); });

  form.addEventListener('submit', async e => {
    e.preventDefault();
    if (!validate(current)) return;

    submitBtn.textContent = 'Submitting...';
    submitBtn.disabled = true;

    try {
      const res = await fetch('/api/apply', {
        method: 'POST',
        body: new FormData(form),
      });
      const json = await res.json();

      if (json.ok) {
        formCard.style.display = 'none';
        successCard.style.display = 'flex';
        successCard.scrollIntoView({ behavior: 'smooth', block: 'start' });
      } else {
        submitBtn.textContent = 'Submit application';
        submitBtn.disabled = false;
      }
    } catch {
      submitBtn.textContent = 'Submit application';
      submitBtn.disabled = false;
    }
  });

  goto(1);
</script>
