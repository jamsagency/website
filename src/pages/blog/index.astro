---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';

const posts = [
  {
    title: 'Bubble or Custom Code? How to Know Which Stack Fits Your Product',
    slug: 'leaving-bubble',
    date: '2026-03-17',
    excerpt: "The choice between Bubble and custom code isn't about which platform is better. It's about which one fits your product at its current stage.",
  },
  {
    title: 'How to Migrate from Bubble to Next.js: What the Process Actually Looks Like',
    slug: 'migrate-from-bubble-to-nextjs',
    date: '2026-03-13',
    excerpt: "Migrating from Bubble to Next.js means rebuilding the product, not porting it. Here's what the process looks like, what transfers, and what doesn't.",
  },
  {
    title: "What Bubble Actually Can't Do: A Practical Hard Limits Guide",
    slug: 'bubble-hard-limits',
    date: '2026-03-09',
    excerpt: "Bubble can build almost anything a business software product needs. Almost. Here are the actual structural limits, not the architecture problems people confuse for them.",
  },
  {
    title: 'Bubble vs Custom Code: What the Real Costs Look Like',
    slug: 'bubble-vs-custom-code-cost',
    date: '2026-03-05',
    excerpt: "No-code isn't always cheaper than custom development. The real cost depends on scale, team size, and how much the product changes. Here's the honest picture.",
  },
  {
    title: 'When to Migrate from Bubble: What Actually Triggers a Rebuild',
    slug: 'when-to-migrate-from-bubble',
    date: '2026-03-01',
    excerpt: "Not every Bubble app needs to migrate. Most shouldn't. Here are the signals that actually mean migration is the right call, and the ones that don't.",
  },
  {
    title: 'The Bubble Hybrid Stack: When to Extend Bubble with Cloudflare',
    slug: 'bubble-hybrid-stack',
    date: '2026-02-25',
    excerpt: "When Bubble handles 90% of your product but AI agents or edge compute need more, a Bubble + Cloudflare hybrid solves the gap without a full platform migration.",
  },
  {
    title: 'How to Build an App as a Non-Technical Founder',
    slug: 'how-to-build-app-as-non-technical-founder',
    date: '2026-02-21',
    excerpt: 'How to build an app as a non-technical founder: shape the idea first, choose no-code when it fits, scope ruthlessly, and pick the right build partner.',
  },
  {
    title: 'How to Build a Member Portal in Bubble for Elite Communities',
    slug: 'high-fidelity-member-portal',
    date: '2026-02-17',
    excerpt: 'Custom Bubble member portal for elite communities: personalized dashboards, AI matchmaking, private messaging, and a design that reflects your brand.',
  },
  {
    title: 'How to Build a Full-Funnel Booking Engine in Bubble',
    slug: 'full-funnel-booking-engine',
    date: '2026-02-13',
    excerpt: 'How to build a full-funnel booking engine in Bubble covering lead capture, email nurturing, optimized booking flow, abandonment recovery, and a guest portal.',
  },
  {
    title: 'How to Build a High-Converting Booking Flow in Bubble',
    slug: 'high-converting-booking-flow',
    date: '2026-02-09',
    excerpt: 'Custom booking flow in Bubble with Checkfront for real-time availability and Stripe for payments. Multi-step, mobile-responsive, and fully branded.',
  },
  {
    title: 'How to Connect Checkfront to Bubble for Real-Time Hospitality Management',
    slug: 'connect-checkfront-to-bubble',
    date: '2026-02-05',
    excerpt: 'How to connect Checkfront to Bubble via API. Keep Checkfront for operations, build a premium branded front-end for guests. Step-by-step integration guide.',
  },
  {
    title: 'Custom Booking Technology for Dude Ranches: A Digital Hospitality Guide',
    slug: 'dude-ranch-booking-technology',
    date: '2026-02-01',
    excerpt: 'Custom booking technology for dude ranches in Bubble: branded flows, real-time availability from Checkfront, guest portals, and deposit collection via Stripe.',
  },
];
---

<BaseLayout
  title="Blog — Custom Software, AI, and Digital Operations | Jams"
  description="Practical writing on custom software, AI implementation, and digital operations for business owners and operators."
>
  <!-- Hero -->
  <section class="px-3 pt-4 pb-10 md:px-4 md:pb-12">
    <div class="rounded-[24px] pt-[160px] pb-[80px]" style="background: var(--neutral-100);">
      <div class="container">
        <div class="flex flex-col items-center text-center gap-4">
          <span class="eyebrow">Blog</span>
          <h1 class="font-display text-h1 text-neutral-900">What we've learned building products for operators</h1>
        </div>
      </div>
    </div>
  </section>

  <section class="section hairline">
    <div class="container flex flex-col gap-12">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map((p) => <BlogCard {...p} />)}
      </div>
    </div>
  </section>
</BaseLayout>
