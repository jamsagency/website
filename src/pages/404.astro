---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page not found | Jams"
  description="The page you're looking for doesn't exist."
  noindex={true}
>
  <section style="min-height: calc(100vh - 200px); display: flex; align-items: center; justify-content: center; padding: 100px 24px;">
    <div style="text-align: center; max-width: 480px;">
      <p style="font-family: 'Instrument Serif', serif; font-size: clamp(80px, 15vw, 140px); line-height: 1; color: #0B0B0B; margin: 0 0 24px;">404</p>
      <h1 style="font-family: 'Neue Haas Grotesk Display Pro', sans-serif; font-size: clamp(20px, 4vw, 28px); font-weight: 500; color: #0B0B0B; margin: 0 0 16px;">This page doesn't exist</h1>
      <p style="font-family: 'Neue Haas Grotesk Display Pro', sans-serif; font-size: 16px; color: #404040; line-height: 1.6; margin: 0 0 40px;">The URL might be wrong, or the page may have moved. Head back to the homepage and we'll get you sorted.</p>
      <a href="/" class="btn-primary" style="display: inline-block; font-family: 'Neue Haas Grotesk Display Pro', sans-serif; font-size: 15px; font-weight: 500; color: #fff; text-decoration: none; padding: 12px 28px; border-radius: 12px;">Back to homepage</a>
    </div>
  </section>
</BaseLayout>
