---
import LandingPageLayout from '../layouts/LandingPageLayout.astro';
import CTASection from '../components/CTASection.astro';

const faqs = [
  { q: 'What exactly do you build?', a: 'Custom web and mobile applications. Not websites, not templates, not off-the-shelf SaaS tools with your logo on them. We build products from scratch: booking platforms, marketplaces, community platforms, internal ops tools, AI-powered apps. If your business has a specific workflow and no existing software handles it the way you need, that is what we build.' },
  { q: 'Do you work with no-code? What does that mean for us?', a: 'Yes. Our primary build tool is Bubble, the most powerful no-code platform available. In practice, it means we build faster and at a lower cost than traditional development, without compromising the end result. Bubble handles payments, AI integrations, real-time data, complex logic, and multi-role platforms.' },
  { q: 'How do you scope a project and how is it priced?', a: 'Every engagement starts with a Blueprint: a paid, two-week discovery process where we define exactly what gets built, in what order, and why. The Blueprint starts at $3,500. Development runs as a monthly engagement: $8,000 per month for a full dedicated team, or $5,000 per month for a sprint-based model.' },
  { q: 'How long does a typical project take?', a: 'The Blueprint takes two weeks. After that, most first-version products ship in 8 to 12 weeks depending on complexity.' },
  { q: 'Who owns the code and design at the end?', a: 'You do. The Figma files, the Bubble application, all design assets, all documentation transfer to you at the end of the engagement. We have never held a client\'s product hostage.' },
];
---

<LandingPageLayout
  title="Custom Booking Software for Hospitality Operators | Jams"
  description="Custom booking platforms for boutique ranches, retreats, and experiential properties — integrated with Checkfront, built around your brand."
  vertical="Custom Booking Software for Hospitality Operators"
>

  <!-- Hero -->
  <section class="px-3 pt-4 pb-10 md:px-4 md:pb-12">
    <div class="rounded-[24px] pt-[120px] pb-[64px]" style="background: var(--neutral-100);">
      <div class="container">
        <div class="max-w-2xl flex flex-col gap-6">
          <span class="eyebrow">Hospitality</span>
          <h1 class="font-display text-h1 text-neutral-900">
            Your guests choose you for something they cannot get anywhere else. Your booking experience should make that clear from the first click.
          </h1>
          <p class="font-sans text-p-l text-neutral-700">
            Most boutique hospitality operators have a physical experience their software cannot match. Guests find you on Airbnb, call to check availability, or give up mid-booking. We build custom booking platforms that handle real-time availability, payments, and guest communication — integrated with the systems you already use, designed to match the experience you actually deliver.
          </p>
          <a href="/start" class="btn-primary self-start rounded-pill py-4 px-9">Apply to work with Jams</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Who this is for -->
  <section class="section hairline">
    <div class="container">
      <div class="max-w-2xl flex flex-col gap-6">
        <h2 class="eyebrow">This is for you if</h2>
        <ul class="flex flex-col gap-3">
          {[
            'You run a boutique ranch, retreat, glamping operation, or experiential property',
            'You are paying commission to Airbnb or a booking aggregator on reservations you could be taking directly',
            'Your current booking tool does not match the quality of your physical experience',
          ].map((item) => (
            <li class="flex items-start gap-3 font-sans text-p text-neutral-700">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-violet-500 shrink-0" aria-hidden="true"></span>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- The problem -->
  <section class="section hairline">
    <div class="container">
      <div class="max-w-2xl flex flex-col gap-6">
        <h2 class="eyebrow">What is actually happening</h2>
        <p class="font-sans text-p-l text-neutral-700">
          Most hospitality operators are managing bookings through a combination of Airbnb, email, and phone calls. It works until it does not. Staff spend hours on quote requests that should be confirmed reservations. Availability is never fully in sync. Guests who find you organically hit a booking experience that feels nothing like your property.
        </p>
        <p class="font-sans text-p-l text-neutral-700">
          The software that exists for hospitality — Checkfront, Rezdy, FareHarbor — is designed for volume, not craft. It handles the transaction but it cannot reflect your brand, your pricing logic, or the specific way your operation works. So you end up paying platform commissions on bookings you should own, or you lose guests who could not figure out how to book at all.
        </p>
      </div>
    </div>
  </section>

  <!-- What we build -->
  <section class="section hairline">
    <div class="container">
      <div class="max-w-2xl flex flex-col gap-8">
        <h2 class="eyebrow">What we build for hospitality operators</h2>
        <p class="font-sans text-p-l text-neutral-700">Custom booking platforms designed around how your operation actually works. That means:</p>
        <ul class="flex flex-col gap-3">
          {[
            'A guest-facing booking flow built to your brand, not a white-label template',
            'Real-time availability connected to your existing management system',
            'Payment processing at booking (deposit or full amount, your choice)',
            'Automated email notifications at every stage of the guest journey',
            'A backend view where your team has full visibility of every reservation and its status',
          ].map((item) => (
            <li class="flex items-start gap-3 font-sans text-p text-neutral-700">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-violet-500 shrink-0" aria-hidden="true"></span>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Case study -->
  <section class="section hairline dark bg-neutral-950">
    <div class="container">
      <div class="max-w-2xl flex flex-col gap-6">
        <h2 class="eyebrow text-neutral-400">Red Horse Mountain Ranch, Idaho</h2>
        <p class="font-sans text-p-l text-neutral-300">
          Red Horse is a luxury all-inclusive ranch in Idaho. Before working with Jams, their website could not take a direct booking. Every inquiry came through Airbnb or a contact form. Their reservation manager handled each one manually.
        </p>
        <p class="font-sans text-p-l text-neutral-300">
          We built a custom booking platform integrated with their existing system (Checkfront) and Stripe for payment. Guests can see real availability, choose their dates and cabin preferences, and pay a deposit in a single flow. Everything syncs back to Checkfront automatically.
        </p>
        <p class="font-sans text-p-l font-medium text-white">
          Eight weeks after launch: 1,600 users. 80 leads. Zero online bookings before. Direct bookings now the default.
        </p>
        <blockquote class="border-l-2 border-violet-500 pl-6">
          <p class="font-display text-h4 text-white">"Their communication and follow-up were a pleasure to work with."</p>
          <footer class="font-sans text-p-s text-neutral-400 mt-2">Don Britton, Owner, Red Horse Mountain Ranch</footer>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="section hairline">
    <div class="container flex flex-col gap-12">
      <h2 class="eyebrow">What happens when you apply</h2>
      <ol class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          { n: '1', title: 'Apply', body: 'Fill out the form below. It takes about 5 minutes. Tell us about the property, the booking problem, and what you are working with right now.' },
          { n: '2', title: 'Discovery call', body: 'We review your submission and schedule a 45-minute call. We ask about your operation, your current tools, and what a successful booking experience looks like for your guests. No pitch, no deck.' },
          { n: '3', title: 'The Blueprint', body: 'If there is a fit, every engagement starts with a Blueprint: a two-week paid process where we map your operation, design the booking flow, and produce a complete build plan before any development starts.' },
        ].map(({ n, title, body }) => (
          <li class="flex flex-col gap-4">
            <span class="font-display text-h3 text-violet-500">{n}</span>
            <h3 class="font-display text-h4 text-neutral-900">{title}</h3>
            <p class="font-sans text-p text-neutral-700">{body}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section hairline">
    <div class="container">
      <div class="max-w-2xl flex flex-col gap-10">
        <h2 class="font-display text-h2 text-neutral-900">Common questions</h2>
        <dl class="flex flex-col divide-y divide-neutral-150">
          {faqs.map(({ q, a }) => (
            <details class="group py-6">
              <summary class="flex items-center justify-between gap-4 cursor-pointer list-none font-display text-h4 text-neutral-900">
                {q}
                <span class="shrink-0 text-violet-500 transition-transform duration-fast group-open:rotate-45" aria-hidden="true">+</span>
              </summary>
              <p class="font-sans text-p text-neutral-700 mt-4 leading-relaxed">{a}</p>
            </details>
          ))}
        </dl>
      </div>
    </div>
  </section>

  <!-- CTA / Form -->
  <CTASection
    headline="Your guests choose you for something they cannot get anywhere else. Your booking experience should reflect that."
    body="Apply below. We review every submission and reach out within 24 hours."
  />

</LandingPageLayout>
