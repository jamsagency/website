---
import BaseLayout from './BaseLayout.astro';
import CTASection from '@components/CTASection.astro';

interface Props {
  title: string;
  description: string;
  publishDate: string;
  author?: string;
  image?: string;
  slug: string;
}

const {
  title,
  description,
  publishDate,
  author = 'Juan Germano',
  image,
  slug,
} = Astro.props;

const formattedDate = new Date(publishDate).toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  author: { '@type': 'Person', name: author },
  datePublished: publishDate,
  image: image ? new URL(image, 'https://jams.agency').toString() : undefined,
  publisher: { '@type': 'Organization', name: 'Jams', url: 'https://jams.agency' },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://jams.agency' },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://jams.agency/blog' },
    { '@type': 'ListItem', position: 3, name: title },
  ],
};
---

<BaseLayout {title} {description} schema={articleSchema}>

  <!-- Hero -->
  <section class="px-3 pt-4 pb-10 md:px-4 md:pb-12">
    <div class="rounded-[24px] overflow-hidden" style="background: var(--neutral-100);">
      <div class="container pt-[120px] pb-[64px]">
        <div class="max-w-2xl flex flex-col gap-6">
          <!-- Breadcrumb -->
          <nav aria-label="Breadcrumb">
            <ol class="flex items-center gap-2 font-sans text-p-xs text-neutral-500">
              <li><a href="/" class="hover:text-neutral-900 transition-colors duration-fast">Home</a></li>
              <li aria-hidden="true">/</li>
              <li><a href="/blog" class="hover:text-neutral-900 transition-colors duration-fast">Blog</a></li>
              <li aria-hidden="true">/</li>
              <li class="text-neutral-900 truncate max-w-[240px]" aria-current="page">{title}</li>
            </ol>
          </nav>
          <!-- Title + meta -->
          <div class="flex flex-col gap-3">
            <h1 class="font-display text-h1 text-neutral-900">{title}</h1>
            <div class="flex items-center gap-3 font-sans text-p-s text-neutral-500">
              <time datetime={publishDate}>{formattedDate}</time>
              <span aria-hidden="true">&middot;</span>
              <span>{author}</span>
            </div>
          </div>
        </div>
      </div>
      <!-- Featured image: full width, flush to bottom edge -->
      {image && (
        <img
          src={image}
          alt={title}
          width="1240"
          height="700"
          class="w-full h-auto block"
          loading="eager"
        />
      )}
    </div>
  </section>

  <!-- Body -->
  <article class="section">
    <div class="container">
      <div class="max-w-2xl mx-auto flex flex-col gap-10">
        <div class="prose prose-neutral max-w-none font-sans">
          <slot />
        </div>
      </div>
    </div>
  </article>

  <CTASection />

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BaseLayout>
