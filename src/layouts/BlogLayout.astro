---
import BaseLayout from './BaseLayout.astro';
import CTASection from '@components/CTASection.astro';

interface Props {
  title: string;
  description: string;
  publishDate: string;
  author?: string;
  image?: string;
  slug: string;
}

const {
  title,
  description,
  publishDate,
  author = 'Juan Germano',
  image,
  slug,
} = Astro.props;

const formattedDate = new Date(publishDate).toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  author: { '@type': 'Person', name: author },
  datePublished: publishDate,
  image: image ? new URL(image, 'https://jams.agency').toString() : undefined,
  publisher: { '@type': 'Organization', name: 'Jams', url: 'https://jams.agency' },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://jams.agency' },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://jams.agency/blog' },
    { '@type': 'ListItem', position: 3, name: title },
  ],
};
---

<BaseLayout {title} {description} schema={articleSchema}>
  <!-- Breadcrumb -->
  <nav class="py-6" aria-label="Breadcrumb">
    <div class="container">
      <ol class="flex items-center gap-2 font-sans text-p-xs text-neutral-500">
        <li><a href="/" class="hover:text-neutral-900 transition-colors duration-fast">Home</a></li>
        <li aria-hidden="true">/</li>
        <li><a href="/blog" class="hover:text-neutral-900 transition-colors duration-fast">Blog</a></li>
        <li aria-hidden="true">/</li>
        <li class="text-neutral-900 truncate max-w-[200px]" aria-current="page">{title}</li>
      </ol>
    </div>
  </nav>

  <article class="section">
    <div class="container">
      <div class="max-w-2xl flex flex-col gap-12">
        <!-- Header -->
        <header class="flex flex-col gap-4">
          <h1 class="font-display text-h1 text-neutral-900">{title}</h1>
          <div class="flex items-center gap-4 font-sans text-p-s text-neutral-500">
            <time datetime={publishDate}>{formattedDate}</time>
            <span aria-hidden="true">&middot;</span>
            <span>{author}</span>
          </div>
        </header>

        <!-- Featured image -->
        {image && (
          <div class="rounded-2xl overflow-hidden">
            <img
              src={image}
              alt={title}
              width="800"
              height="450"
              class="w-full h-auto"
              loading="eager"
            />
          </div>
        )}

        <!-- Body -->
        <div class="prose prose-neutral max-w-none font-sans">
          <slot />
        </div>
      </div>
    </div>
  </article>

  <CTASection />

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BaseLayout>
