---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  vertical?: string;
  schema?: object;
}

const { title, description, vertical, schema: propSchema } = Astro.props;

const serviceSchema = propSchema ?? (vertical ? {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: vertical,
  provider: { '@type': 'Organization', name: 'Jams', url: 'https://jams.agency' },
  areaServed: 'Worldwide',
} : undefined);
---

<BaseLayout {title} {description} schema={serviceSchema}>
  <slot />
</BaseLayout>
